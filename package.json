{
	"name": "hi-note",
	"version": "0.5.7",
	"description": "Enhance your highlighted notes with comment management and export features.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"deploy": "npm run build && node deploy.mjs",
		"deploy:dev": "node deploy.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"esbuild": "^0.25.0",
		"happy-dom": "^20.10.6",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "^4.7.4",
		"vitest": "^2.0.0"
	},
	"dependencies": {
		"@codemirror/view": "^6.42.1",
		"html2canvas": "^1.4.1",
		"minimatch": "^10.0.1",
		"ts-fsrs": "^5.0.1"
	}
}
